# ===== Base de Datos =====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mikioscoedu?schema=public"

# ===== Autenticación =====
JWT_SECRET="TuSecretoSeguroDeAlMenos16Caracteres"
JWT_EXPIRES_IN="15m"
KIOSK_JWT_EXPIRES_IN="30m"

# ===== Servidor =====
PORT=3000
NODE_ENV=development

# ===== Mercado Pago (opcional) =====
MP_ACCESS_TOKEN=""
MP_WEBHOOK_URL=""
MP_WEBHOOK_SECRET=""

# ===== Docker (opcional, solo si usas docker-compose) =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mikioscoedu
DB_PORT=5432
BACKEND_PORT=3000
